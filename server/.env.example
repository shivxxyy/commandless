# CommandLess AI proxy — server-side secrets (never committed)
#
# Local dev:  cp server/.env.example server/.env  then fill in OLLAMA_API_KEY.
# Production: set these as environment variables in your host's dashboard.

# Your Ollama Cloud API key. Stays on the server only.
OLLAMA_API_KEY=

# Ollama Cloud endpoint (default is correct for ollama.com).
OLLAMA_HOST=https://ollama.com

# Cloud model. Examples: gpt-oss:120b, gpt-oss:20b, qwen3-coder:480b.
OLLAMA_MODEL=gpt-oss:120b

# Port (hosts usually inject PORT automatically).
PORT=8787

# CORS origin(s). "*" is fine; the desktop app isn't a normal browser origin.
ALLOWED_ORIGIN=*

# --- abuse / cost guards (recommended in production) ---------------------
# Shared token the desktop app sends as `x-commandless-token`. Set the SAME
# value here and as the app's VITE_APP_TOKEN at build time. Deters casual
# abuse (it ships in the app, so it is not a true secret).
APP_TOKEN=

# Per-IP request limit per minute.
RATE_PER_MIN=15

# Global cap on billable model calls per day (protects your bill).
DAILY_CAP=1500
