# CommandLess environment configuration
#
# CommandLess never stores a real AI API key inside the desktop app.
# The default "proxy" provider calls your own backend, which holds the
# Ollama Cloud (or other) API key server-side.
#
# Point this at your backend. The app POSTs to: ${VITE_AI_PROXY_URL}/command
#
# Using the bundled local proxy (npm run proxy)? Use:
#   VITE_AI_PROXY_URL=http://localhost:8787/api/ai
VITE_AI_PROXY_URL=http://localhost:8787/api/ai

# Optional: default local Ollama base URL (only used if you choose the
# "Local Ollama" provider in Settings). No key required.
VITE_OLLAMA_URL=http://localhost:11434

# Optional: default model name used by the local Ollama provider.
VITE_OLLAMA_MODEL=llama3.1
